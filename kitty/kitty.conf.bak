# vim:fileencoding=utf-8:foldmethod=marker

# ==============================================================================
# 字体设置 (Fonts)
# ==============================================================================

# 字体大小 (单位: 点)
font_size 12.0

# 强制从左到右显示文本 (yes: 强制LTR, no: 自动检测)
force_ltr no

# 符号字体映射 (格式: Unicode范围 字体名称)
# 用于指定特定 Unicode 范围使用的字体
# symbol_map

# 限制符号渲染宽度 (格式: Unicode范围 单元格数)
# narrow_symbols

# 禁用连字 (never: 从不禁用, cursor: 光标处禁用, always: 总是禁用)
disable_ligatures always

# 字体特性 (OpenType 特性控制)
# font_features

# 修改字体属性 (可用属性: cell_width, cell_height, baseline, underline_position, underline_thickness, strikethrough_position, strikethrough_thickness)
modify_font cell_height 1.1

# 框线绘制比例 (4个数值，用于调整框线字符的粗细)
# box_drawing_scale 0.001, 1, 1.5, 2

# 下划波浪线样式 (thin-sparse: 细疏, thin-dense: 细密, thick-sparse: 粗疏, thick-dense: 粗密)
# undercurl_style thin-sparse

# 下划线与文本的间隙厚度 (数字/px/pt)
# underline_exclusion 1

# 文本合成策略 (platform: 平台默认, legacy: 传统模式, 或指定对比度数值)
# text_composition_strategy platform

# 前景色覆盖阈值 (0: 禁用, 数字: 比率或百分比)
# text_fg_override_threshold 0


# ==============================================================================
# 光标设置 (Text Cursor)
# ==============================================================================

# 光标颜色 (颜色值或 none: 使用反色)
# cursor #cccccc

# 光标下文本颜色 (颜色值或 background: 使用背景色)
# cursor_text_color #111111

# 光标形状 (block: 方块, beam: 竖线, underline: 下划线)
cursor_shape block

# 失去焦点时的光标形状 (block: 方块, beam: 竖线, underline: 下划线, hollow: 空心方块, unchanged: 保持不变)
# cursor_shape_unfocused hollow

# beam 光标粗细 (单位: 点)
# cursor_beam_thickness 1.5

# underline 光标粗细 (单位: 点)
# cursor_underline_thickness 2.0

# 光标闪烁间隔 (单位: 秒, -1: 使用系统默认, 0: 禁用闪烁)
cursor_blink_interval -1

# 停止闪烁的时间 (单位: 秒, 0: 从不停止闪烁)
cursor_stop_blinking_after 0

# 启用光标拖尾效果 (0: 禁用, 1: 启用)
cursor_trail 1

# 拖尾衰减时间范围 (两个数值，单位: 秒)
cursor_trail_decay 0.1 0.4

# 拖尾起始阈值 (移动超过多少个字符才显示拖尾)
cursor_trail_start_threshold 2

# 拖尾颜色 (颜色值或 none: 使用光标颜色)
cursor_trail_color none


# ==============================================================================
# 滚动设置 (Scrollback)
# ==============================================================================

# 回滚缓冲区行数 (历史记录保存的行数)
scrollback_lines 2000

# 滚动条显示时机 (scrolled: 滚动时显示, hovered: 悬停时显示, scrolled-and-hovered: 滚动或悬停时显示, always: 总是显示, never: 从不显示)
scrollbar scrolled

# 滚动条是否可交互 (yes: 可点击拖动, no: 仅显示)
scrollbar_interactive yes

# 点击滚动条时是否跳转到点击位置 (yes: 跳转, no: 不跳转)
# scrollbar_jump_on_click yes

# 滚动条宽度 (单位: 单元格宽度)
# scrollbar_width 0.5

# 悬停时滚动条宽度 (单位: 单元格宽度)
# scrollbar_hover_width 1

# 滚动条手柄不透明度 (0-1)
# scrollbar_handle_opacity 0.5

# 滚动条圆角半径
# scrollbar_radius 0.3

# 滚动条与窗口边缘的间隙
# scrollbar_gap 0.1

# 滚动条手柄最小高度 (单位: 单元格高度)
# scrollbar_min_handle_height 1

# 滚动条点击区域扩展 (单位: 单元格宽度)
# scrollbar_hitbox_expansion 0.25

# 滚动条轨道不透明度 (0-1)
# scrollbar_track_opacity 0

# 悬停时滚动条轨道不透明度 (0-1)
# scrollbar_track_hover_opacity 0.1

# 滚动条手柄颜色 (颜色值或 foreground: 使用前景色)
# scrollbar_handle_color foreground

# 滚动条轨道颜色 (颜色值或 foreground: 使用前景色)
# scrollbar_track_color foreground

# 分页器程序 (用于查看滚动历史的外部程序)
# scrollback_pager less --chop-long-lines --RAW-CONTROL-CHARS +INPUT_LINE_NUMBER

# 分页器历史大小 (单位: MB, 0: 禁用)
# scrollback_pager_history_size 0

# 扩大窗口时是否用历史记录填充 (yes: 填充, no: 不填充)
scrollback_fill_enlarged_window yes

# 鼠标滚轮滚动倍数
# wheel_scroll_multiplier 5.0

# 最小滚动行数
# wheel_scroll_min_lines 1

# 触摸板滚动倍数
# touch_scroll_multiplier 1.0


# ==============================================================================
# 鼠标设置 (Mouse)
# ==============================================================================

# 隐藏鼠标指针的等待时间 (单位: 秒, 0: 立即隐藏, 负数: 从不隐藏)
# mouse_hide_wait 3.0

# URL 颜色
# url_color #0087bd

# URL 下划线样式 (none: 无, straight: 直线, double: 双线, curly: 波浪线, dotted: 点线, dashed: 虚线)
# url_style curly

# 打开 URL 的程序 (default: 系统默认浏览器)
# open_url_with default

# URL 前缀列表 (识别为 URL 的协议前缀)
# url_prefixes file ftp ftps gemini git gopher http https irc ircs kitty mailto news sftp ssh

# 是否检测 URL (yes: 检测, no: 不检测)
detect_urls yes

# URL 排除字符 (这些字符不会被包含在 URL 中)
# url_excluded_characters

# 显示超链接目标 (yes: 显示, no: 不显示)
# show_hyperlink_targets no

# 超链接下划线 (hover: 悬停时显示, always: 总是显示, never: 从不显示)
# underline_hyperlinks hover

# 选择时复制 (no: 不复制, clipboard: 复制到剪贴板, 或指定缓冲区名称)
copy_on_select clipboard

# 剪贴板丢失时清除选择 (yes: 清除, no: 不清除)
# clear_selection_on_clipboard_loss no

# 粘贴动作 (quote-urls-at-prompt: 引用URL, confirm: 确认多行粘贴, confirm-if-large: 大文本时确认, filter: 过滤控制字符, no-op: 无操作)
# paste_actions quote-urls-at-prompt,confirm

# 去除尾随空格 (never: 从不, smart: 智能, always: 总是)
strip_trailing_spaces smart

# 双击选词时包含的字符
# select_by_word_characters @-./_~?&=%+#

# 向前选词时包含的字符
# select_by_word_characters_forward

# 点击间隔 (单位: 秒, -1: 使用系统默认)
# click_interval -1.0

# 焦点跟随鼠标 (yes: 鼠标移动到窗口时自动获得焦点, no: 需要点击)
# focus_follows_mouse no

# 抓取时的指针形状 (arrow: 箭头, beam: 竖线, hand: 手形等)
# pointer_shape_when_grabbed arrow

# 默认指针形状 (arrow: 箭头, beam: 竖线, hand: 手形等)
# default_pointer_shape beam

# 拖动时的指针形状
# pointer_shape_when_dragging beam crosshair

# 清除所有默认鼠标动作 (yes: 清除, no: 保留)
# clear_all_mouse_actions no


# ==============================================================================
# 性能调优 (Performance Tuning)
# ==============================================================================

# 重绘延迟 (单位: 毫秒, 降低可提高响应速度但增加 CPU 使用)
repaint_delay 10

# 输入延迟 (单位: 毫秒, 降低可提高输入响应速度)
input_delay 3

# 与显示器刷新率同步 (yes: 同步, no: 不同步)
sync_to_monitor yes


# ==============================================================================
# 终端响铃 (Terminal Bell)
# ==============================================================================

# 启用音频响铃 (yes: 启用, no: 禁用)
enable_audio_bell no

# 视觉响铃持续时间 (单位: 秒, 0: 禁用视觉响铃)
# visual_bell_duration 0.0

# 视觉响铃颜色 (颜色值或 none: 使用默认)
# visual_bell_color none

# 响铃时窗口提醒 (yes: 在 Dock/任务栏闪烁, no: 不提醒)
window_alert_on_bell yes

# 标签页响铃符号 (响铃时在标签标题显示的符号)
# bell_on_tab "🔔 "

# 响铃时执行的命令 (none: 不执行)
# command_on_bell none

# 响铃音频文件路径 (none: 使用系统默认)
# bell_path none

# Linux 响铃主题 (__custom: 自定义, 或主题名称)
# linux_bell_theme __custom


# ==============================================================================
# 窗口布局 (Window Layout)
# ==============================================================================

# 记住窗口大小 (yes: 记住上次关闭时的大小, no: 使用初始大小)
remember_window_size  no

# 初始窗口宽度 (单位: 像素, 或 单元格数c)
initial_window_width  1200

# 初始窗口高度 (单位: 像素, 或 单元格数c)
initial_window_height 700

# 记住窗口位置 (yes: 记住, no: 不记住)
remember_window_position no

# 启用的布局 (*: 所有布局, 或指定: fat, grid, horizontal, splits, stack, tall, vertical)
enabled_layouts *

# 调整窗口大小步长 - 单元格 (按单元格调整时每次调整的单元格数)
# window_resize_step_cells 2

# 调整窗口大小步长 - 行 (按行调整时每次调整的行数)
# window_resize_step_lines 2

# 窗口边框宽度 (单位: pt/px)
# window_border_width 0.5pt

# 绘制最小边框 (yes: 只在需要时绘制边框, no: 总是绘制)
# draw_minimal_borders yes

# 单窗口时绘制边框 (yes: 绘制, no: 不绘制)
# draw_window_borders_for_single_window no

# 窗口外边距 (单位: 点, 可指定 1-4 个值)
# window_margin_width 0

# 单窗口外边距 (-1: 使用 window_margin_width)
# single_window_margin_width -1

# 窗口内边距 (单位: 点, 可指定 1-4 个值)
window_padding_width 10

# 单窗口内边距 (-1: 使用 window_padding_width)
# single_window_padding_width -1

# 窗口放置策略 (top-left, top, top-right, left, center, right, bottom-left, bottom, bottom-right)
# placement_strategy center

# 活动窗口边框颜色
# active_border_color #00ff00

# 非活动窗口边框颜色
# inactive_border_color #cccccc

# 响铃窗口边框颜色
# bell_border_color #ff5a00

# 非活动窗口文本透明度 (0-1, 1: 完全不透明)
# inactive_text_alpha 1.0

# 隐藏窗口装饰 (no: 不隐藏, yes: 隐藏全部, titlebar-only: 只隐藏标题栏, titlebar-and-corners: 隐藏标题栏和圆角)
# hide_window_decorations no

# 窗口 Logo 路径 (none: 不显示)
# window_logo_path none

# 窗口 Logo 位置 (top-left, top, top-right, left, center, right, bottom-left, bottom, bottom-right)
# window_logo_position bottom-right

# 窗口 Logo 透明度 (0-1)
# window_logo_alpha 0.5

# 窗口 Logo 缩放 (0-100, 0: 自动)
# window_logo_scale 0

# 调整大小防抖时间 (两个数值，单位: 秒)
# resize_debounce_time 0.1 0.5

# 按单元格调整大小 (yes: 按单元格步进, no: 平滑调整)
# resize_in_steps no

# 可视窗口选择字符 (用于 focus_visible_window 等操作)
# visual_window_select_characters 1234567890ABCDEFGHIJKLMNOPQRSTUVWXYZ

# 关闭确认窗口数 (-1: 有多个窗口时确认, 0: 从不确认, 正数: 超过该数量时确认)
# confirm_os_window_close -1


# ==============================================================================
# 标签栏设置 (Tab Bar)
# ==============================================================================

# 标签栏位置 (top: 顶部, bottom: 底部)
tab_bar_edge top

# 标签栏左右边距 (单位: 点)
tab_bar_margin_width 0.0

# 标签栏上下边距 (两个数值: 上边距 下边距)
tab_bar_margin_height 0.0 0.0

# 标签栏样式 (fade: 渐变, slant: 斜角, separator: 分隔符, powerline: 电力线, custom: 自定义, hidden: 隐藏)
tab_bar_style powerline

# 标签栏过滤器 (搜索表达式，用于过滤显示的标签)
# tab_bar_filter

# 标签栏对齐 (left: 左对齐, center: 居中, right: 右对齐)
tab_bar_align left

# 最小标签数 (小于此数量时不显示标签栏)
tab_bar_min_tabs 2

# 标签切换策略 (previous: 切换到上一个活动标签, left: 切换到左边, right: 切换到右边, last: 切换到最后一个)
tab_switch_strategy previous

# 标签淡化程度 (fade 样式使用，多个数值表示渐变)
# tab_fade 0.25 0.5 0.75 1

# 标签分隔符 (separator 样式使用)
# tab_separator " ┇"

# Powerline 样式 (angled: 尖角, slanted: 倾斜, round: 圆角)
tab_powerline_style slanted

# 标签活动符号 (有活动时在标签标题显示的符号)
# tab_activity_symbol none

# 标签标题最大长度 (0: 不限制)
# tab_title_max_length 0

# 标签标题模板 (支持变量: title, index, num_windows, num_window_groups, layout_name, tab.active_wd 等)
tab_title_template "{fmt.fg.red}{bell_symbol}{activity_symbol}{fmt.fg.tab}{tab.last_focused_progress_percent}{title}"

# 活动标签标题模板 (none: 使用 tab_title_template)
# active_tab_title_template none

# 活动标签前景色
# active_tab_foreground #000

# 活动标签背景色
# active_tab_background #eee

# 活动标签字体样式 (normal, bold, italic, bold-italic)
# active_tab_font_style bold-italic

# 非活动标签前景色
# inactive_tab_foreground #444

# 非活动标签背景色
# inactive_tab_background #999

# 非活动标签字体样式 (normal, bold, italic, bold-italic)
# inactive_tab_font_style normal

# 标签栏背景色 (none: 使用默认)
# tab_bar_background none

# 标签栏边距颜色 (none: 使用默认)
# tab_bar_margin_color none


# ==============================================================================
# 颜色方案 (Color Scheme)
# ==============================================================================

# 前景色
# foreground #dddddd

# 背景色
# background #000000

# 背景不透明度 (0-1, 1: 完全不透明)
background_opacity 1

# 背景模糊度 (0: 不模糊, 数值越大越模糊)
background_blur 0

# 透明背景色列表 (用于指定多个透明背景色)
# transparent_background_colors

# 动态背景不透明度 (yes: 允许通过快捷键调整, no: 固定)
# dynamic_background_opacity no

# 背景图片路径 (none: 不使用)
# background_image none

# 背景图片布局 (tiled: 平铺, mirror-tiled: 镜像平铺, scaled: 缩放, clamped: 限制, centered: 居中, cscaled: 居中缩放)
# background_image_layout tiled

# 背景图片线性插值 (yes: 平滑, no: 像素化)
# background_image_linear no

# 背景着色 (0-1, 用于在背景图片上叠加背景色)
# background_tint 0.0

# 间隙背景着色 (0-1)
# background_tint_gaps 1.0

# 暗淡文本不透明度 (用于 dim 文本样式)
# dim_opacity 0.4

# 选择前景色
# selection_foreground #000000

# 选择背景色
# selection_background #fffacd

# 16 色调色板 (color0-color15)
# color0 #000000
# color1 #cc0403
# color2 #19cb00
# color3 #cecb00
# color4 #0d73cc
# color5 #cb1ed1
# color6 #0dcdcd
# color7 #dddddd
# color8 #767676
# color9 #f2201f
# color10 #23fd00
# color11 #fffd00
# color12 #1a8fff
# color13 #fd28ff
# color14 #14ffff
# color15 #ffffff

# 标记颜色 (用于 mark 功能)
# mark1_foreground black
# mark1_background #98d3cb
# mark2_foreground black
# mark2_background #f2dcd3
# mark3_foreground black
# mark3_background #f274bc


# ==============================================================================
# 高级设置 (Advanced)
# ==============================================================================

# Shell 程序 (.: 使用用户默认 shell)
# shell .

# 编辑器程序 (.: 使用 $VISUAL 或 $EDITOR 环境变量)
# editor .

# 子进程退出时关闭窗口 (yes: 关闭, no: 保持打开)
# close_on_child_death no

# 远程控制密码 (格式: 密码 允许的动作)
# remote_control_password

# 允许远程控制 (no: 禁用, yes: 启用, password: 需要密码, socket-only: 仅 socket, socket: socket 模式)
# allow_remote_control no

# 监听地址 (用于远程控制的 socket 地址)
# listen_on none

# 环境变量 (格式: 变量名=值)
# env

# 通知过滤规则
# filter_notification

# 监视器 (Python 文件路径，用于自定义事件处理)
# watcher

# 可执行文件搜索路径
# exe_search_path

# 更新检查间隔 (单位: 小时, 0: 禁用)
update_check_interval 0

# 启动会话文件 (none: 不使用)
# startup_session none

# 剪贴板控制 (允许的剪贴板操作)
# clipboard_control write-clipboard write-primary read-clipboard-ask read-primary-ask

# 剪贴板最大大小 (单位: MB)
# clipboard_max_size 512

# 文件传输确认绕过密码
# file_transfer_confirmation_bypass

# 允许超链接 (yes: 允许, no: 禁止, ask: 询问)
# allow_hyperlinks yes

# Shell 集成 (enabled: 启用, disabled: 禁用, no-cursor: 禁用光标形状, no-title: 禁用标题, no-cwd: 禁用工作目录, no-prompt-mark: 禁用提示标记, no-complete: 禁用补全, no-sudo: 禁用 sudo)
shell_integration enabled

# 允许克隆 (ask: 询问, yes: 允许, no: 禁止)
# allow_cloning ask

# 克隆源策略 (venv, conda, env_var, path)
# clone_source_strategies venv,conda,env_var,path

# 命令完成通知 (never: 从不, unfocused: 窗口失焦时, invisible: 窗口不可见时, always: 总是)
notify_on_cmd_finish unfocused

# TERM 环境变量值
term xterm-256color

# TERMINFO 类型 (path: 路径, direct: 直接, none: 无)
# terminfo_type path

# 转发标准输入输出 (yes: 转发, no: 不转发)
# forward_stdio no

# 菜单映射 (自定义右键菜单)
# menu_map


# ==============================================================================
# macOS 特定设置 (OS Specific - macOS)
# ==============================================================================

# 标题栏颜色 (system: 系统默认, light: 浅色, dark: 深色, background: 使用背景色, 或指定颜色值)
# macos_titlebar_color system

# Option 键作为 Alt (no: 不作为 Alt, left: 左 Option, right: 右 Option, both: 两个都是)
# macos_option_as_alt no

# 从任务切换器隐藏 (yes: 隐藏, no: 显示)
# macos_hide_from_tasks no

# 最后一个窗口关闭时退出 (yes: 退出, no: 保持运行)
# macos_quit_when_last_window_closed no

# 窗口可调整大小 (yes: 可调整, no: 固定大小)
macos_window_resizable yes

# 加粗字体 (0: 不加粗, 正数: 加粗程度)
# macos_thicken_font 0

# 传统全屏模式 (yes: 使用传统全屏, no: 使用原生全屏)
macos_traditional_fullscreen no

# 显示窗口标题位置 (all: 窗口和菜单栏, window: 仅窗口, menubar: 仅菜单栏, none: 不显示)
macos_show_window_title_in all

# 菜单栏标题最大长度 (0: 不限制)
# macos_menubar_title_max_length 0

# 自定义 beam 光标 (yes: 使用自定义, no: 使用系统默认)
# macos_custom_beam_cursor no

# 色彩空间 (srgb: sRGB, default: 系统默认, displayp3: Display P3)
macos_colorspace default


# ==============================================================================
# 快捷键设置 (Keyboard Shortcuts)
# ==============================================================================

# 默认修饰键 (用于 kitty_mod 的快捷键)
# kitty_mod ctrl+shift

# 清除所有快捷键 (yes: 清除所有默认快捷键, no: 保留)
clear_all_shortcuts no

# 动作别名 (格式: 别名 动作)
# action_alias

# Kitten 别名 (格式: 别名 kitten)
# kitten_alias

# Cmd+Enter 新建窗口
map cmd+enter   new_window
# 用 Cmd+W 关闭当前分屏
map cmd+w   close_window

# 用 Option + 左右箭头切换 Tab
map alt+left    previous_tab
map alt+right   next_tab


# ==============================================================================
# 底部自动管理区域 (主题与字体)
# ==============================================================================

# BEGIN_KITTY_THEME
# Tokyo Night
include current-theme.conf
# END_KITTY_THEME

# BEGIN_KITTY_FONTS
font_family      family='JetBrainsMonoNL Nerd Font Mono' postscript_name=JetBrainsMonoNLNFM-Regular
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS
